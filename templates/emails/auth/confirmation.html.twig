{#
  Template d'email de confirmation de compte

  templates/emails/auth/confirmation.html.twig
  
  Variables requises:
    - user: Objet utilisateur avec les propriétés firstname, username, email
    - confirmationUrl: URL de confirmation du compte
    - expires_in: Durée de validité du lien (optionnel, défaut: "24 heures")
  
  Variables optionnelles:
    - preview: Si true, on est en mode preview (pas d'envoi réel)
#}
{% extends 'layouts/email.html.twig' %}

{% set subject = 'Confirmez votre compte ' ~ app_name %}
{% set preheader = 'Cliquez pour activer votre compte et commencer à utiliser ' ~ app_name %}

{% block content %}
  {# Titre principal #}
  {% include 'emails/components/_text.html.twig' with {
    level: 'h1',
    content: 'Bienvenue sur ' ~ app_name ~ ' !',
    custom_style: 'margin-bottom:20px'
  } %}

  {# Texte d'introduction #}
  {% include 'emails/components/_text.html.twig' with {
    level: 'p',
    content: 'Bonjour <strong>' ~ (user.firstname|default(user.username|default('cher utilisateur'))) ~ '</strong>,'
  } %}

  {% include 'emails/components/_text.html.twig' with {
    level: 'p',
    content: 'Merci de vous être inscrit sur <strong>' ~ app_name ~ '</strong>. Pour finaliser la création de votre compte et accéder à tous nos services, veuillez confirmer votre adresse email en cliquant sur le bouton ci-dessous :'
  } %}

  {# Bouton de confirmation #}
  {% include 'emails/components/_button.html.twig' with {
    url: confirmationUrl,
    label: 'Confirmer mon compte',
    custom_style: 'margin: 30px auto; text-align: center;'
  } %}

  {# Info utilisateur #}
  {% include 'emails/components/_box.html.twig' with {
    background: '#f5f5f5',
    padding: '15px 20px',
    radius: '8px',
    content: '
      <table width="100%" cellpadding="0" cellspacing="0" style="font-size: 14px; margin-bottom: 0;">
        <tr>
          <td width="100" style="padding: 8px 0; color: #737373;">Identifiant :</td>
          <td style="padding: 8px 0; color: #262626;"><strong>' ~ user.username|default('-') ~ '</strong></td>
        </tr>
        <tr>
          <td width="100" style="padding: 8px 0; color: #737373;">Email :</td>
          <td style="padding: 8px 0; color: #262626;">' ~ user.email ~ '</td>
        </tr>
      </table>
    ',
    custom_style: 'margin: 20px auto;'
  } %}

  {% include 'emails/components/_divider.html.twig' %}

  {# Lien alternatif #}
  {% include 'emails/components/_text.html.twig' with {
    level: 'small',
    content: 'Si le bouton ne fonctionne pas, copiez et collez ce lien dans votre navigateur :',
    color: '#737373',
    custom_style: 'margin: 10px 0;'
  } %}

  {% include 'emails/components/_box.html.twig' with {
    background: '#fafafa',
    padding: '10px 15px',
    radius: '6px',
    content: '<a href="' ~ confirmationUrl ~ '" style="color: #404040; font-size: 12px; word-break: break-all;">' ~ confirmationUrl ~ '</a>'
  } %}

  {% include 'emails/components/_divider.html.twig' %}

  {# Alerte de sécurité #}
  {% include 'emails/components/_alert.html.twig' with {
    type: 'info',
    content: '<strong>Vous n\'avez pas créé ce compte ?</strong><br>Si vous n\'êtes pas à l\'origine de cette inscription, vous pouvez ignorer cet email. Le compte ne sera pas activé et sera automatiquement supprimé.',
    custom_style: 'margin: 10px auto;'
  } %}

  {# Message de fin #}
  {% include 'emails/components/_text.html.twig' with {
    level: 'p',
    content: 'À très bientôt sur ' ~ app_name ~ ' !'
  } %}
{% endblock %}