{# Props: items (array), bullet_color, custom_style #}
{% set items = items|default([]) %}
{% set bullet_color = bullet_color|default('#404040') %} {# ds-primary #}
{% set custom_style = custom_style|default('') %}
{% set font_family = "system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif" %}

<table width="100%" cellpadding="0" cellspacing="0" style="font-family: {{ font_family }}; margin: 0; {{ custom_style }}">
  {% for item in items %}
  <tr>
    <td width="20" style="font-family: {{ font_family }}; vertical-align: top; padding: 4px 0; color: {{ bullet_color }}; font-size: 14px;" valign="top">&#8226;</td>
    <td style="font-family: {{ font_family }}; vertical-align: top; padding: 4px 0; color: #525252; font-size: 14px; line-height: 1.6;" valign="top">{{ item|raw }}</td>
  </tr>
  {% endfor %}
</table>