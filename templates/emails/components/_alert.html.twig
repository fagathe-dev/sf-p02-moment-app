{# Props: type (success|danger|warning|info), content, custom_style #}
{% set type = type|default('info') %}
{% set content = content|default('') %}
{% set custom_style = custom_style|default('') %}

{% set colors = {
  success: { bg: '#f0fdf4', border: '#16a34a', text: '#166534' },
  danger:  { bg: '#fef2f2', border: '#dc2626', text: '#991b1b' },
  warning: { bg: '#fffbeb', border: '#f59e0b', text: '#b45309' },
  info:    { bg: '#f0f9ff', border: '#0ea5e9', text: '#0369a1' }
} %}
{% set c = colors[type]|default(colors.info) %}
{% set font_family = "system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif" %}

<table width="100%" cellpadding="0" cellspacing="0" style="font-family: {{ font_family }}; margin: 0; {{ custom_style }}">
  <tr>
    <td style="font-family: {{ font_family }}; background-color: {{ c.bg }}; border-left: 4px solid {{ c.border }}; color: {{ c.text }}; padding: 12px 16px; font-size: 14px; border-radius: 6px;">
      {{ content|raw }}
    </td>
  </tr>
</table>