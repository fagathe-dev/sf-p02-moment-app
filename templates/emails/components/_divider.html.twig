{# Props: color, height, custom_style #}
{% set color = color|default('#e5e5e5') %} {# ds-border-color #}
{% set height = height|default('1px') %}
{% set custom_style = custom_style|default('') %}
{% set font_family = "system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif" %}

<table width="100%" cellpadding="0" cellspacing="0" style="font-family: {{ font_family }}; margin: 0; {{ custom_style }}">
  <tr>
    <td style="font-family: {{ font_family }}; padding: 16px 0;">
      <div style="height: {{ height }}; background-color: {{ color }}; line-height: {{ height }}; font-size: 0;">&nbsp;</div>
    </td>
  </tr>
</table>