{# Props: background, padding, content, custom_style #}
{% set background = background|default('#ffffff') %}
{% set padding = padding|default('24px') %}
{% set content = content|default('') %}
{% set custom_style = custom_style|default('') %}
{% set border_color = '#e5e5e5' %} {# ds-border-color #}
{% set font_family = "system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif" %}

<table width="100%" cellpadding="0" cellspacing="0" style="font-family: {{ font_family }}; margin: 0; border-radius: 8px; border: 1px solid {{ border_color }}; {{ custom_style }}">
  <tr>
    <td style="font-family: {{ font_family }}; padding: {{ padding }}; background-color: {{ background }}; border-radius: 8px;">
      {{ content|raw }}
    </td>
  </tr>
</table>