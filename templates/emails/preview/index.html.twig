{#
  Index de prévisualisation des e-mails (dev uniquement)

  templates/emails/preview/index.html.twig
  
  Variables requises:
    - types: Liste des EmailTypeEnum disponibles
#}
{% extends 'layouts/dashboard.html.twig' %}

{% block css %}
<style>
  .email-preview-card {
    background: #fff;
    border: 1px solid #e5e5e5;
    border-radius: 8px;
    overflow: hidden;
  }
  .email-preview-card .card-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 20px;
    border-bottom: 1px solid #f5f5f5;
    transition: background 0.15s;
  }
  .email-preview-card .card-item:last-child { border-bottom: none; }
  .email-preview-card .card-item:hover { background: #fafafa; }
  .email-preview-card .card-item .label { font-weight: 500; font-size: 15px; color: #262626; }
  .email-preview-card .card-item a {
    display: inline-block;
    padding: 6px 16px;
    background: #404040;
    color: #fff;
    text-decoration: none;
    border-radius: 6px;
    font-size: 13px;
    font-weight: 500;
  }
  .email-preview-card .card-item a:hover { background: #262626; }
  
  /* Badges inspirés de ton nouveau design system */
  .badge-auth { background: #f0f9ff; color: #0369a1; border: 1px solid #0ea5e9; }
  .badge-admin { background: #fef2f2; color: #991b1b; border: 1px solid #dc2626; }
  .badge-other { background: #f5f5f5; color: #525252; border: 1px solid #d4d4d4; }
</style>
{% endblock %}

{% block content %}
  <div class="row">
    <div class="col-lg-8 mx-auto">
      <h4 class="mb-1" style="color: #262626;">📧 Prévisualisation des e-mails</h4>
      <p class="text-muted mb-4">{{ types|length }} template(s) disponible(s) — Environnement de développement</p>

      <div class="email-preview-card">
        {% for type in types %}
          {% set badge_class = type.value starts with 'auth_' ? 'badge-auth' : (type.value starts with 'admin_' ? 'badge-admin' : 'badge-other') %}
          {% set group = type.value starts with 'auth_' ? 'Auth' : (type.value starts with 'admin_' ? 'Admin' : 'Général') %}
          
          <div class="card-item">
            <div>
              <span class="badge {{ badge_class }} me-2">{{ group }}</span>
              <span class="label">{{ type.name|replace({'_': ' '})|title }}</span>
              <div class="text-muted small mt-1" style="font-family: monospace;">{{ type.value }}</div>
            </div>
            <div>
              <a href="{{ path('admin_email_preview', { type: type.value }) }}" target="_blank">
                <i class="ri-eye-line me-1"></i> Voir
              </a>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
{% endblock %}