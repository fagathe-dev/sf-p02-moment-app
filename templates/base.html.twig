<!doctype html>
<html lang="fr">
<head>
 <meta charset="utf-8" />
  <title>{{ title is defined ? title|capitalize  ~ ' | ': ''  }} {{ APP_NAME }}</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta content="Boilerplate" name="description" />
  <meta content="Frédérick AGATHE <agathefrederick@gmail.com>" name="author" />
  <!-- App favicon -->
  <link rel="shortcut icon" href="{{ asset(APP_FAVICON) }}" type="image/x-icon">
  <link rel="icon" href="{{ asset(APP_LOGO) }}" type="image/webp">
  <link rel="apple-touch-icon" href="{{ asset(APP_LOGO_PNG) }}" type="image/png">
  <!-- Custom Css-->
  <link href="{{ asset('css/custom.css') }}" rel="stylesheet" type="text/css" />
  <!-- Custom Css-->
  <link href="{{ asset('css/icons.css') }}" rel="stylesheet" type="text/css" />
  {% block head %}{% endblock %}
  {% block stylesheets %}{% endblock %}
</head>

<body {% block body_attributes %}{% endblock %}>

  {% block body %}{% endblock %}

  <!-- JAVASCRIPT -->
  {% block javascripts %}
    <script src="{{ asset('js/main.js') }}"></script>
  {% endblock %}
</body>
</html>