{% extends 'layouts/app.html.twig' %}

{% block content %}
  <div class="card">
    <div class="card-body p-4">
      <div class="col-xl-2 col-lg-4 col-md-6">
        <div class="text-center">

          {# ── Avatar avec bouton caméra en superposition ────────────────── #}
          <div class="profile-user avatar avatar--2xl profile-avatar mx-auto mb-4" id="navbar-user-avatar">

            <img
              src="{% if app.user.avatar %}{{ asset(app.user.avatar) }}{% endif %}"
              class="profile-avatar__img user-profile-image{% if not app.user.avatar %} d-none{% endif %}"
              alt="Photo de profil de {{ app.user.username }}"
            >
            {% if not app.user.avatar %}
              <div class="profile-avatar__fallback">
                {{ app.user.username|first|upper }}
              </div>
            {% endif %}

            <label
              class="profile-avatar__edit"
              for="profile-img-file-input"
              aria-label="Changer la photo de profil"
              title="Changer la photo de profil"
            >
              <i class="ri-camera-line" aria-hidden="true"></i>
              <input
                id="profile-img-file-input"
                type="file"
                class="profile-img-file-input d-none"
                accept="image/*"
              >
            </label>

          </div>

          <h5 class="fs-16 mb-1">@{{ app.user.username }}</h5>
          {# <p class="text-muted mb-0">{{ app.user.role }}</p> #}

        </div>
      </div>
    </div>
  </div>

  {% include 'auth/profile/tabs/index.html.twig' %}
{% endblock %}

{% block js %}
  <script src="{{ asset('js/pages/auth/profile.js') }}"></script>
{% endblock %}
