{#
  ================================================================
  _bottom_nav.html.twig
  Barre de navigation inférieure mobile (Bottom Navigation Bar).

  Visible uniquement en dessous du breakpoint LG (< 992 px) via CSS.

  VARIANTES : modifier la classe modificatrice sur <nav> :
    .bottom-nav--stacked  (défaut)
      → icône au-dessus du label, pilule colorée sur l'icône seule
    .bottom-nav--inline
      → icône + label côte à côte, pilule englobant le bloc entier

  TYPES DE LIENS SUPPORTÉS :
    1. Ancre simple        href="#section-id"
       → défilement fluide géré par BottomNav.ts
    2. Toggle tab          data-bs-toggle="tab" + data-bs-target="#panel"
       → changement de panneau délégué au composant Tab.ts
  ================================================================
#}

{# ── Détermination de la route active ─────────────────────────── #}
{% set _route = app.request.attributes.get('_route')|default('') %}

{# ── Configuration des liens de navigation ────────────────────── #}
{% set app_nav_links = [
  {
    'id': 'feed',
    'label': 'Feed',
    'url': url('app_view_feed'),
    'icon': 'mdi mdi-cards-variant',
    'is_active': _route == 'app_view_feed' or (_route starts with 'app_journal_' and not (_route starts with 'app_vault_'))
  },
  {
    'id': 'insights',
    'label': 'Insights',
    'url': url('app_view_insights'),
    'icon': 'mdi mdi-widgets-outline',
    'is_active': _route == 'app_view_insights' or _route starts with 'app_category_'
  },
  {
    'id': 'vault',
    'label': 'Coffre-fort',
    'url': url('app_vault_journal_index'),
    'icon': 'mdi mdi-lock-outline',
    'is_active': _route starts with 'app_vault_'
  },
  {
    'id': 'profile',
    'label': 'Profil',
    'url': url('auth_profile_index'),
    'icon': 'mdi mdi-account-circle-outline',
    'is_active': _route starts with 'auth_profile_'
  }
] %}

<nav
  class="bottom-nav bottom-nav--stacked"
  id="bottomNav"
  aria-label="Navigation principale"
>
  <ul class="bottom-nav__list" role="list">

    {% for link in app_nav_links %}
      <li class="bottom-nav__item">
        <a
          class="bottom-nav__link {{ link.is_active ? 'active' : '' }}"
          href="{{ link.url }}"
          {{ link.is_active ? 'aria-current="page"' : '' }}
        >
          <span class="bottom-nav__icon" aria-hidden="true">
            {# Gestion spécifique de l'avatar pour le bouton Profil #}
            {% if link.id == 'profile' and app.user %}
              {% if app.user.avatar %}
                <span class="avatar avatar--sm">
                  <img src="{{ asset(app.user.avatar) }}" alt="">
                </span>
              {% else %}
                <span class="avatar avatar--sm avatar--primary">
                  {{ app.user.username|first|upper }}
                </span>
              {% endif %}
            {% else %}
              {# Affichage classique de l'icône #}
              <i class="{{ link.icon }}"></i>
            {% endif %}
          </span>
          <span class="bottom-nav__label">{{ link.label }}</span>
        </a>
      </li>
    {% endfor %}

  </ul>
</nav>