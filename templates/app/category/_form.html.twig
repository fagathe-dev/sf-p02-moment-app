{{ form_start(form, {'attr': {'class': 'row g-3 align-items-center'}}) }}

  {{ form_row(form.name) }}

  {{ form_row(form.description) }}

  {# Champ couleur — CustomSelector (single-nullable) #}
  {% include 'components/_custom-dropdown-select.html.twig' with {
    'field':           form.color,
    'cds_mode':        'single-nullable',
    'cds_placeholder': 'Choisir une couleur...',
  } only %}

  {{ form_row(form.slug) }}

  <div class="col-auto">
    {{ form_widget(form.save) }}
    <a href="{{ path('app_category_index') }}" class="btn btn-light ms-2">Annuler</a>
  </div>

{{ form_end(form) }}
