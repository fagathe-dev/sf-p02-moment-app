{% extends 'base.html.twig' %}

{% block stylesheets %}
  {% block css %}{% endblock %}
{% endblock %}

{% block javascripts %}
  {% block js %}{% endblock %}
{% endblock %}
  
{% block body %}
  <div class="auth-page-wrapper pt-5">

    <!-- auth page content -->
    <div class="auth-page-content">
      <div class="container">
        <div class="row">
          <div class="col-lg-12">
            <div class="text-center mt-sm-5 mb-4 text-white-50">
              <div>
                <a href="/" class="d-inline-block auth-logo">
                  <img src="{{ asset(APP_LOGO) }}" alt="" height="50" style="height: 50px; width: auto;">
                </a>
              </div>
              <p class="mt-3 fs-15 fw-medium">{{ APP_NAME }}</p>
            </div>
          </div>
        </div>
            <!-- end row -->

        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6 col-xl-5">
                <div class="card mt-4">

                    <div class="card-body p-4">
                        {% block auth_header %}
                          <div class="text-center mt-2">
                            <h5 class="text-primary">Bon retour !</h5>
                            <p class="text-muted">Connectez-vous à {{ APP_NAME }}.</p>
                          </div>
                        {% endblock %}
                        <div class="p-2 mt-4">
                          {% include 'fragments/_flash_messages.html.twig' %}
                          {% block auth_content %}{% endblock %}
                        </div>
                    </div>
                    <!-- end card body -->
                </div>
                <!-- end card -->

                {% block auth_footer %}
                  <div class="mt-4 text-center">
                    <p class="mb-0">Don't have an account ? <a href="auth-signup-basic" class="fw-semibold text-primary text-decoration-underline"> Signup </a> </p>
                  </div>
                {% endblock %}

            </div>
        </div>
        <!-- end row -->
      </div>
      <!-- end container -->
    </div>
    <!-- end auth page content -->

    <!-- footer -->
    <footer class="footer">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <div class="text-center">
                        <p class="mb-0 text-muted">&copy;
                            {{ "now"|date("Y") }} {{ APP_NAME }}. Développé avec <i class="mdi mdi-heart text-danger"></i> par <a href="https://github.com/fagathe-dev" target="_blank">fagathe-dev</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </footer>
    <!-- end Footer -->
  </div>
{% endblock %}