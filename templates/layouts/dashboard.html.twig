{% extends 'base.html.twig' %}

{% block stylesheets %}
  {% block css %}{% endblock %}
{% endblock %}

{% block javascripts %}
  <script src="{{ asset('js/main.js') }}"></script>
  {% block js %}{% endblock %}
{% endblock %}

{% block body %}
  {# ── Enveloppe principale du tableau de bord (Desktop First) ───────────── #}
  <div class="dashboard-wrapper">

    {# ── Barre latérale ────────────────────────────────────────────────────── #}
    <aside class="dashboard-sidebar" id="dashboard-sidebar" aria-label="Navigation du tableau de bord">
      {% include 'fragments/_sidebar_dashboard.html.twig' %}
    </aside>

    {# ── Colonne principale ────────────────────────────────────────────────── #}
    <div class="dashboard-main">

      {# Top bar #}
      <header class="dashboard-header" id="dashboard-header">
        {% include 'fragments/_navbar_dashboard.html.twig' %}
      </header>

      {# Zone de contenu #}
      <main class="dashboard-content" id="main-content">
        <div class="dashboard-content__inner">

          {# Fil d'Ariane (affiché si la variable `breadcrumb` est définie par le contrôleur) #}
          {% include 'fragments/_breadcrumb.html.twig' %}

          {# Messages flash #}
          {% include 'fragments/_flash_messages.html.twig' %}

          {# ── Pilules de catégorisation (style Apple Finder) ─────────────── #}
          {# Surcharger ce block depuis les vues enfants pour afficher des tags #}
          {% block category_pills %}{% endblock %}

          {# ── Contenu principal de la page ──────────────────────────────── #}
          {% block content %}{% endblock %}

        </div>
        {# end dashboard-content__inner #}
      </main>
      {# end main #}

      {# Pied de page #}
      {% include 'fragments/_footer_dashboard.html.twig' %}

    </div>
    {# end dashboard-main #}

  </div>
  {# end dashboard-wrapper #}
{% endblock %}