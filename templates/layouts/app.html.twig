{% extends 'base.html.twig' %}

{% block stylesheets %}
  {% block css %}{% endblock %}
{% endblock %}

{% block javascripts %}
  <script src="{{ asset('js/main.js') }}"></script>
  {% block js %}{% endblock %}
{% endblock %}

{% block body %}
  {# ── Enveloppe principale de l'application (Mobile First) ──────────────── #}
  <div class="app-wrapper">


    {# Contenu principal de l'application (à droite de la sidebar) #}

    {# Section hero (optionnelle, surchargeable depuis les vues enfants) #}
    {% block hero %}{% endblock %}

    {# Contenu principal #}
    <main class="container-fluid" id="main-content">
      {% include 'fragments/_breadcrumb.html.twig' %}
      {% include 'fragments/_flash_messages.html.twig' %}
      {% block content %}{% endblock %}
    </main>

    {# Bouton "Retour en haut de page" #}
    {% include 'fragments/_top_button.html.twig' %}

    {# Barre de navigation inférieure — visible uniquement sur mobile (< 992 px) #}
    {% include 'fragments/_bottom_nav.html.twig' %}

  </div>
  {# end app-wrapper #}
{% endblock %}
